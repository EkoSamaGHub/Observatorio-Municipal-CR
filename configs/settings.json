{
  "crawler": {
    "max_depth": 5,
    "request_delay": 2,
    "max_retries": 3,
    "timeout_seconds": 30,
    "respect_robots": true,
    "max_pages_per_site": 1000
  },

  "storage": {
    "save_raw_html": true,
    "compress_html": false,
    "save_pdfs": true,
    "historical_snapshots": true
  },

  "monitoring": {
    "enable_change_tracking": true,
    "enable_broken_link_checks": true
  }
}