# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real credentials.

# TigerData / Timescale cloud Postgres connection string
# Leave empty to use local SQLite (development)
DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require

# ── Admin control center ────────────────────────────────────────────────────
# Required to enable the /admin API + dashboard. If unset, every /admin endpoint
# returns 503 (the control plane is disabled and never exposed publicly).
# Use a long random string. Set this on the Railway API service.
ADMIN_TOKEN=

# ── Admin Discord SSO ──────────────────────────────────────────────────────
# When configured, /admin/auth/discord/login triggers Discord OAuth and sets a
# signed session cookie; only users whose Discord ID is in ADMIN_DISCORD_IDS
# get past the allowlist. The legacy X-Admin-Token header still works as a
# fallback for scripts/curl.
#
# 1) Discord dev portal (https://discord.com/developers/applications) → your
#    app → OAuth2. Copy the Client ID (= app ID) and Client Secret.
# 2) Add the redirect URI below to OAuth2 → Redirects exactly as written.
# 3) ADMIN_DISCORD_IDS is a comma-separated list of Discord user IDs (enable
#    Developer Mode in Discord, right-click your name → Copy User ID).
# 4) ADMIN_FRONTEND_URL is where the OAuth callback redirects after login AND
#    the CORS allowlist for credentialed admin requests (comma-separated for
#    multiple, e.g. prod + localhost).
# 5) SESSION_SECRET is optional — defaults to ADMIN_TOKEN. Set explicitly if
#    you ever rotate ADMIN_TOKEN without wanting to invalidate active sessions.
DISCORD_CLIENT_ID=1507884755469996205
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://your-api.up.railway.app/admin/auth/discord/callback
ADMIN_DISCORD_IDS=239638966033186827
ADMIN_FRONTEND_URL=https://observatorio-municipal-cr.vercel.app
# SESSION_SECRET=

# Optional: let the admin "Start crawl" button spin up real GitHub Actions
# workers on demand. Create a fine-grained PAT with Actions: read+write on this
# repo. Without these, "Start crawl" still enqueues a run for the nightly
# workflow / Railway monitor to pick up.
GH_DISPATCH_TOKEN=
GH_REPO=EkoSamaGHub/Observatorio-Municipal-CR
# GH_WORKFLOW_FILE=crawl.yml
# GH_WORKFLOW_REF=main
